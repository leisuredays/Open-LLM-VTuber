# 기반 모델 설정
FROM benedict/linkbricks-llama3.1-korean:8b

# 1. 컨텍스트 및 성능 파라미터 조절
PARAMETER num_ctx 16384
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER stop "<|start_header_id|>"
